{
  "name": "madscode",
  "displayName": "MADSCode",
  "repository": {
    "type": "git",
    "url": "https://github.com/MADS-NET/MADSCode.git"
  },
  "description": "Visual Studio Code support for the MADS framework.",
  "version": "0.0.10",
  "author": {
    "name": "Paolo Bosetti",
    "url": "https://mads-net.github.io"
  },
  "keywords": [
    "mads",
    "visual studio code",
    "extension",
    "network",
    "simulation",
    "agent-based",
    "data science"
  ],
  "publisher": "MADS-Net",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/mads128x128.png",
  "scripts": {
    "lint": "node --check extension.js",
    "validate": "npm run lint && node -e \"JSON.parse(require('node:fs').readFileSync('package.json', 'utf8')); console.log('package.json ok')\"",
    "vscode:prepublish": "npm run validate",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  },
  "activationEvents": [
    "onView:mads.info",
    "onView:mads.control",
    "onView:mads.configurations",
    "onView:mads.plugins",
    "onCommand:mads.refreshFiles",
    "onCommand:mads.refreshInfo",
    "onCommand:mads.refreshPlugins",
    "onCommand:mads.startFile",
    "onCommand:mads.stopFile",
    "onCommand:mads.startActiveIniFile",
    "onCommand:mads.generateIniFile",
    "onCommand:mads.generateDirectorFile",
    "onCommand:mads.createPlugin",
    "onCommand:mads.launchChat"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mads",
          "title": "MADS",
          "icon": "media/mads.svg"
        }
      ]
    },
    "views": {
      "mads": [
        {
          "id": "mads.info",
          "name": "MADS Info"
        },
        {
          "id": "mads.control",
          "name": "Control"
        },
        {
          "id": "mads.configurations",
          "name": "Configurations"
        },
        {
          "id": "mads.plugins",
          "name": "Plugins"
        }
      ]
    },
    "commands": [
      {
        "command": "mads.refreshFiles",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "mads.refreshInfo",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "mads.refreshPlugins",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "mads.startFile",
        "title": "Start",
        "icon": "$(play-circle)"
      },
      {
        "command": "mads.stopFile",
        "title": "Stop",
        "icon": "$(stop-circle)"
      },
      {
        "command": "mads.startActiveIniFile",
        "title": "Start Active MADS File",
        "icon": "$(play)"
      },
      {
        "command": "mads.generateIniFile",
        "title": "Generate INI File",
        "icon": "$(build)"
      },
      {
        "command": "mads.generateDirectorFile",
        "title": "Generate Director File",
        "icon": "$(build)"
      },
      {
        "command": "mads.createPlugin",
        "title": "Create A New One",
        "icon": "$(build)"
      },
      {
        "command": "mads.openTreeLink",
        "title": "Open Link",
        "icon": "$(link-external)"
      },
      {
        "command": "mads.launchChat",
        "title": "Launch Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "mads.revealTreePath",
        "title": "Open Folder",
        "icon": "$(folder-opened)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mads.refreshInfo",
          "when": "view == mads.info",
          "group": "navigation"
        },
        {
          "command": "mads.refreshFiles",
          "when": "view == mads.control",
          "group": "navigation"
        },
        {
          "command": "mads.refreshPlugins",
          "when": "view == mads.plugins",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "mads.startFile",
          "when": "view == mads.control && viewItem == controlFileStopped",
          "group": "inline"
        },
        {
          "command": "mads.stopFile",
          "when": "view == mads.control && viewItem == controlFileRunning",
          "group": "inline"
        },
        {
          "command": "mads.generateIniFile",
          "when": "view == mads.configurations && viewItem == configurationGenerateIni",
          "group": "inline"
        },
        {
          "command": "mads.generateDirectorFile",
          "when": "view == mads.configurations && viewItem == configurationGenerateDirector",
          "group": "inline"
        },
        {
          "command": "mads.createPlugin",
          "when": "view == mads.plugins && viewItem == pluginCreate",
          "group": "inline"
        },
        {
          "command": "mads.openTreeLink",
          "when": "view =~ /^mads\\./ && viewItem == externalLink",
          "group": "inline"
        },
        {
          "command": "mads.launchChat",
          "when": "view == mads.info && viewItem == chatCommand",
          "group": "inline"
        },
        {
          "command": "mads.revealTreePath",
          "when": "view =~ /^mads\\./ && viewItem == openableFolder",
          "group": "inline"
        }
      ],
      "editor/title": [
        {
          "command": "mads.startActiveIniFile",
          "when": "resourceExtname == .ini || resourceExtname == .toml",
          "group": "navigation"
        }
      ]
    }
  }
}
